<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NurMontage" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#ff059669</item>
        <item name="colorPrimaryDark">#ff047857</item>
        <item name="colorAccent">#ff10b981</item>
        <item name="android:windowBackground">@color/studio</item>
        <item name="android:statusBarColor">@color/studio</item>
        <item name="android:navigationBarColor">@color/studio</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <style name="Theme.NurMontage.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/studio</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.NurMontage</item>
    </style>

    <style name="CustomSeekBarStyle" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressBackgroundTint">#ff808080</item>
        <item name="android:progressTint">#ff059669</item>
        <item name="android:thumbTint">#ff10b981</item>
    </style>
</resources>
